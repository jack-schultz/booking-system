# Copy to .env and adjust for your Supabase project.
# This allows developer testing with local .env file

# These are publishable (anon) keys, safe for client-side use.
# Using an env keeps project-specific values out of git.

# For GitHub Pages, add these as repository secrets (Settings → Secrets and variables
# → Actions → Repository secrets). Secret names must match exactly

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# PowerSync Dashboard → select instance → Connect → copy instance URL
VITE_POWERSYNC_URL=https://your-instance.powersync.journeyapps.com
