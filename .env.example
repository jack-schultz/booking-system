# Copy to .env and adjust for your Supabase project.
# This allows developer testing with local .env file

# These are publishable (anon) keys, safe for client-side use.
# Using an env keeps project-specific values out of git.

# When hosting with GitHub pages, these are required to be added as environment secrets
# It is is then accessed by the .github/workflows/deploy.yml using:
#    VITE_SUPABASE_URL: ${{ secrets.VITE_SUPABASE_URL }}
#    VITE_SUPABASE_ANON_KEY: ${{ secrets.VITE_SUPABASE_ANON_KEY }}

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
